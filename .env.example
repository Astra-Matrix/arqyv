# ARQYV Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── General ─────────────────────────────────────────────────────────────────
ARQYV_THEME=dark
ARQYV_LANGUAGE=en
ARQYV_ENABLE_AI=true
ARQYV_ENABLE_VOICE_SEARCH=true
ARQYV_ENABLE_CLOUD_SYNC=false
ARQYV_ENABLE_AUTO_INDEX=true
ARQYV_ENABLE_API_SERVER=true
ARQYV_API_PORT=8765

# ── AI ───────────────────────────────────────────────────────────────────────
ARQYV_AI_WHISPER_MODEL=base          # tiny | base | small | medium | large
ARQYV_AI_DEVICE=auto                 # auto | cpu | cuda | mps
ARQYV_AI_MAX_WORKERS=4
ARQYV_AI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Database (monolith / Version A) ─────────────────────────────────────────
# Leave blank to use default: <user_data_dir>/ARQYV/arqyv.db (SQLite)
ARQYV_DB_URL=
ARQYV_DB_ECHO=false

# ── Version B — Docker microservices ────────────────────────────────────────
# Required for `docker compose up`. Use a strong password in production.
ARQYV_DB_PASSWORD=changeme

# Full SQLAlchemy URL — set automatically by docker-compose via DATABASE_URL.
# Override here only if connecting to an external Postgres instance.
DATABASE_URL=

# Redis URL — set automatically by docker-compose.
# Override here for an external Redis cluster.
REDIS_URL=redis://localhost:6379/0

# Path on the HOST machine to mount as /library inside containers.
ARQYV_LIBRARY_PATH=./library

# Log verbosity for the API container (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# AI worker parallelism
AI_WORKER_POOL=4

# ── Cloud – Google Drive ─────────────────────────────────────────────────────
ARQYV_CLOUD_GOOGLE_CLIENT_ID=
ARQYV_CLOUD_GOOGLE_CLIENT_SECRET=

# ── Cloud – OneDrive ────────────────────────────────────────────────────────
ARQYV_CLOUD_ONEDRIVE_CLIENT_ID=

# ── Cloud – Dropbox ──────────────────────────────────────────────────────────
ARQYV_CLOUD_DROPBOX_APP_KEY=
ARQYV_CLOUD_DROPBOX_APP_SECRET=

# ── Optional integrations ────────────────────────────────────────────────────
# OpenAI key — only needed if using GPT-based AI features (optional)
OPENAI_API_KEY=
