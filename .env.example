# ARQYV Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── General ────────────────────────────────────────────────────────────────
ARQYV_THEME=dark
ARQYV_LANGUAGE=en
ARQYV_ENABLE_AI=true
ARQYV_ENABLE_VOICE_SEARCH=true
ARQYV_ENABLE_CLOUD_SYNC=false
ARQYV_ENABLE_AUTO_INDEX=true

# ── AI ─────────────────────────────────────────────────────────────────────
ARQYV_AI_WHISPER_MODEL=base          # tiny | base | small | medium | large
ARQYV_AI_DEVICE=auto                 # auto | cpu | cuda | mps
ARQYV_AI_MAX_WORKERS=4
ARQYV_AI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Database ───────────────────────────────────────────────────────────────
# Leave blank to use default: <user_data_dir>/ARQYV/arqyv.db
ARQYV_DB_URL=
ARQYV_DB_ECHO=false

# ── Cloud – Google Drive ───────────────────────────────────────────────────
ARQYV_CLOUD_GOOGLE_CLIENT_ID=
ARQYV_CLOUD_GOOGLE_CLIENT_SECRET=

# ── Cloud – OneDrive ──────────────────────────────────────────────────────
ARQYV_CLOUD_ONEDRIVE_CLIENT_ID=

# ── Cloud – Dropbox ───────────────────────────────────────────────────────
ARQYV_CLOUD_DROPBOX_APP_KEY=
ARQYV_CLOUD_DROPBOX_APP_SECRET=
